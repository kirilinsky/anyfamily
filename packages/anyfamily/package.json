{
  "name": "anyfamily",
  "version": "1.0.3",
  "description": "The whole any* family in one install — anywhen, anyamount, anymany, anyaround and anylong: micro Intl formatters with zero dependencies of their own.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "intl",
    "i18n",
    "l10n",
    "localization",
    "zero-dependencies",
    "formatter",
    "date",
    "relative-time",
    "number",
    "currency",
    "units",
    "list",
    "listformat",
    "region",
    "language",
    "flags",
    "meta-package",
    "anywhen",
    "anyamount",
    "anymany",
    "anyaround",
    "anylong",
    "duration"
  ],
  "homepage": "https://anyfamily.site",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/anyfamily.git",
    "directory": "packages/anyfamily"
  },
  "bugs": {
    "url": "https://github.com/kirilinsky/anyfamily/issues"
  },
  "author": "kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT",
  "dependencies": {
    "anyamount": "^1.0.0",
    "anyaround": "^1.0.0",
    "anylong": "^1.0.1",
    "anymany": "^1.0.1",
    "anywhen": "^1.0.3"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}